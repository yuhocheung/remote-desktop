# ─── 必填 ───────────────────────────────────────────────────────────
# 对外域名（caddy 申请 TLS 证书 + wss 入口）。例：signal.example.com
DOMAIN=

# TURN 服务器公网 IP（VPS 的外网地址；NAT 后必须显式指定，否则 relay 候选不可达）。
TURN_EXTERNAL_IP=

# TURN 长效凭据（coturn --user）。客户端经 RDCORE_TURN_USER / RDCORE_TURN_PASS 注入。
# 即：下面两行的值 = 客户端侧 export RDCORE_TURN_USER / RDCORE_TURN_PASS 的值。
# 默认值须与本仓库 config.rs 的内置联调凭据保持一致（目前 = 84d9e…），
# 否则纯 IP 联调部署下 App/Host 与 coturn 的 TURN 鉴权对不上。
# 生产环境请改为随机长串，并改用动态凭据（coturn use-auth-secret）经安全通道下发。
TURN_USER=rdcore
TURN_PASS=84d9e822b2be47739710013bfd15aec91b5cd4363c61b78c

# ─── 可选（有默认值）───────────────────────────────────────────────
TURN_PORT=3478
TURN_REALM=rdcore
TURN_MIN_PORT=49152
TURN_MAX_PORT=65535

# ─── 注意 ───────────────────────────────────────────────────────────
# 本文件仅供 docker compose 使用（coturn + caddy）。Host / Viewer 侧需另设环境变量，
# 见同目录 README.md 的「客户端 / Host 配置」：
#   RDCORE_SIGNALING=wss://<DOMAIN>/signaling
#   RDCORE_STUN=stun:<DOMAIN>:3478
#   RDCORE_TURN_URL=turn:<DOMAIN>:3478?transport=udp
#   RDCORE_TURN_USER=<TURN_USER>
#   RDCORE_TURN_PASS=<TURN_PASS>
